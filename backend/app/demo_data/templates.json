[
  {
    "id": "template_sql_injection",
    "rule_id": "rule_sql_injection",
    "version": "1.0.0",
    "search_pattern": "^([ \\t]*)query\\s*=\\s*[\"']SELECT\\s+(.*)\\s+WHERE\\s+(\\w+)\\s*=\\s*[\"']\\s*\\+\\s*(\\w+)",
    "replace_pattern": "\\1query = \"SELECT \\2 WHERE \\3 = ?\"\n\\1params = (\\4,)",
    "expected_match_count": 1,
    "follow_up_replacements": [
      {
        "search_pattern": "db\\.execute\\(query\\)",
        "replace_pattern": "db.execute(query, params)",
        "expected_match_count": 1
      }
    ],
    "additional_imports": [],
    "required_postconditions": [
      "^([ \\t]*)query\\s*=\\s*[\"']SELECT\\s+(.*)\\s+WHERE\\s+(\\w+)\\s*=\\s*\\?[\"']",
      "^([ \\t]*)params\\s*=\\s*\\((\\w+),\\s*\\)",
      "db\\.execute\\(query,\\s*params\\)"
    ],
    "forbidden_postconditions": [
      "query\\s*=\\s*[\"']SELECT.*WHERE.*=[\"']\\s*\\+\\s*\\w+",
      "db\\.execute\\(query\\)\\s*(?!\\s*,\\s*params)"
    ]
  },
  {
    "id": "template_hardcoded_secret",
    "rule_id": "rule_hardcoded_secret",
    "version": "1.0.0",
    "search_pattern": "([A-Z_]+_KEY)\\s*=\\s*[\"']([a-zA-Z0-9_]{6,})[\"']",
    "replace_pattern": "\\1 = os.getenv(\"\\1\")",
    "expected_match_count": 1,
    "follow_up_replacements": [],
    "additional_imports": ["import os"],
    "required_postconditions": [
      "import\\s+os",
      "[A-Z_]+_KEY\\s*=\\s*os\\.getenv\\([\"'][A-Z_]+_KEY[\"']\\)"
    ],
    "forbidden_postconditions": [
      "[A-Z_]+_KEY\\s*=\\s*[\"'][a-zA-Z0-9_]{6,}[\"']"
    ]
  },
  {
    "id": "template_unsafe_shell",
    "rule_id": "rule_unsafe_shell",
    "version": "1.0.0",
    "search_pattern": "subprocess\\.run\\([\"'](\\w+)\\s+([a-zA-Z0-9_\\-]+)\\s*[\"']\\s*\\+\\s*(\\w+),\\s*shell=True\\)",
    "replace_pattern": "subprocess.run([\"\\1\", \"\\2\", \\3], shell=False)",
    "expected_match_count": 1,
    "follow_up_replacements": [],
    "additional_imports": [],
    "required_postconditions": [
      "subprocess\\.run\\(\\[.*\\],\\s*shell=False\\)"
    ],
    "forbidden_postconditions": [
      "shell=True"
    ]
  }
]
